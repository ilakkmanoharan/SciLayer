generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  AUTHOR
  REVIEWER
  EDITOR
  ADMIN
  READER
}

enum ArticleStatus {
  DRAFT
  SUBMITTED
  VALIDATION_FAILED
  VALIDATED
  UNDER_MODERATION
  REVIEWERS_INVITED
  UNDER_REVIEW
  CHANGES_REQUESTED
  APPROVED
  PUBLISHED_PREPRINT
  SUBMITTED_TO_JOURNAL
  JOURNAL_UNDER_REVIEW
  JOURNAL_ACCEPTED
  JOURNAL_REJECTED
  PUBLISHED_JOURNAL_ARTICLE
  WITHDRAWN
}

enum ReviewStatus {
  INVITED
  ACCEPTED_INVITATION
  DECLINED_INVITATION
  REVIEW_SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  REJECTED
}

model User {
  id        String   @id @default(cuid())
  orcidId   String   @unique @map("orcid_id")
  name      String
  email     String?
  affiliation String?
  avatarUrl String?  @map("avatar_url")
  role      UserRole @default(AUTHOR)
  points    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  authoredArticles ArticleAuthor[]
  correspondingArticles Article[] @relation("CorrespondingAuthor")
  reviews Review[] @relation("ReviewerReviews")
  editedReviews Review[] @relation("EditorReviews")
  journals Journal[]
  pointsEvents PointsEvent[]

  @@map("users")
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  abstract    String
  manuscriptMd String      @map("manuscript_md")
  renderedHtml String      @map("rendered_html")
  articleType String       @map("article_type")
  status      ArticleStatus @default(SUBMITTED)
  version     Int          @default(1)
  githubUrl   String       @map("github_url")
  doi         String?
  license     String       @default("CC-BY-4.0")
  correspondingAuthorId String? @map("corresponding_author_id")
  journalId   String?      @map("journal_id")
  classificationId String? @unique @map("classification_id")
  createdAt   DateTime     @default(now()) @map("created_at")
  publishedAt DateTime?    @map("published_at")

  correspondingAuthor User? @relation("CorrespondingAuthor", fields: [correspondingAuthorId], references: [id])
  journal Journal? @relation(fields: [journalId], references: [id])
  classification Classification?
  authors ArticleAuthor[]
  reviews Review[]
  invitations ReviewInvitation[]
  pointsEvents PointsEvent[]
  versions ArticleVersion[]

  @@map("articles")
}

model ArticleAuthor {
  id          String @id @default(cuid())
  articleId   String @map("article_id")
  userId      String? @map("user_id")
  authorOrder Int    @map("author_order")
  affiliation String?
  orcidId     String? @map("orcid_id")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])

  @@map("article_authors")
}

model Journal {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String
  scope       String
  editorUserId String? @map("editor_user_id")
  status      String @default("active")
  createdAt   DateTime @default(now()) @map("created_at")

  editor User? @relation(fields: [editorUserId], references: [id])
  articles Article[]

  @@map("journals")
}

model Review {
  id        String @id @default(cuid())
  articleId String @map("article_id")
  reviewerId String? @map("reviewer_id")
  editorId   String? @map("editor_id")
  status     ReviewStatus @default(INVITED)
  recommendation String?
  commentsToAuthor String? @map("comments_to_author")
  confidentialComments String? @map("confidential_comments")
  submittedAt DateTime? @map("submitted_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  editor User? @relation("EditorReviews", fields: [editorId], references: [id])

  @@map("reviews")
}

model ReviewInvitation {
  id        String @id @default(cuid())
  articleId String @map("article_id")
  reviewerEmail String @map("reviewer_email")
  reviewerOrcidId String? @map("reviewer_orcid_id")
  token     String @unique
  status    ReviewStatus @default(INVITED)
  sentAt    DateTime @default(now()) @map("sent_at")
  respondedAt DateTime? @map("responded_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("review_invitations")
}

model Classification {
  id        String @id @default(cuid())
  articleId String @unique @map("article_id")
  field     String
  subfield  String
  methods   String[]
  tags      String[]
  confidenceScore Float @map("confidence_score")
  modelUsed String @map("model_used")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("classifications")
}

model PointsEvent {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  articleId String? @map("article_id")
  eventType String @map("event_type")
  points    Int
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id])

  @@map("points_events")
}

model ArticleVersion {
  id        String @id @default(cuid())
  articleId String @map("article_id")
  versionNumber Int @map("version_number")
  githubCommitHash String? @map("github_commit_hash")
  manuscriptMd String @map("manuscript_md")
  metadataJson Json @map("metadata_json")
  createdAt DateTime @default(now()) @map("created_at")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, versionNumber])
  @@map("article_versions")
}
